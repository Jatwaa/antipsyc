# ── AntiPsyc — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values. .env is gitignored.

# HTTP API key authentication (C6).
# When set, all /api/* routes require:  Authorization: Bearer <value>
# Leave empty to disable auth (development only).
ANTIPSYC_API_KEY=

# Port the HTTP server listens on (default: 8717).
ANTIPSYC_PORT=8717

# Timeout for http.fetch validator in milliseconds (H5, default: 5000).
ANTIPSYC_HTTP_TIMEOUT_MS=5000

# Comma-separated list of commands the process.run validator may execute (H3).
# Default is empty — no commands are permitted until explicitly listed.
# Example: ANTIPSYC_ALLOWED_COMMANDS=node --check,npm test,npm run lint
ANTIPSYC_ALLOWED_COMMANDS=
